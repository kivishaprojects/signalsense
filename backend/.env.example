# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:3001
TICK_INTERVAL_MS=2000

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-very-long-random-string-here

# ── Postgres ─────────────────────────────────────────────
# Option 1: Full connection URL (Railway / Render / Supabase)
DATABASE_URL=postgresql://user:password@host:5432/signalsense
PGSSL=true

# Option 2: Individual params (local Postgres)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGDATABASE=signalsense

# ── Default superadmin credentials (used on first run only) ──
ADMIN_EMAIL=admin@signalsense.ai
ADMIN_PASSWORD=Admin@1234
